{
  "name": "obsidian-x-bookmarks",
  "version": "1.0.0",
  "description": "Sync your X (Twitter) bookmarks into Obsidian with AI tagging",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "22.19.15",
    "@typescript-eslint/parser": "8.57.1",
    "builtin-modules": "4.0.0",
    "esbuild": "0.25.12",
    "eslint": "9.39.4",
    "eslint-plugin-obsidianmd": "0.1.9",
    "tslib": "2.8.1",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "obsidian": "1.12.3"
  }
}
