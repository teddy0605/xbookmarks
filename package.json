{
  "name": "obsidian-x-bookmarks",
  "version": "1.0.0",
  "description": "Sync your X (Twitter) bookmarks into Obsidian with AI tagging",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "tslib": "^2.6.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "obsidian": "^1.12.3"
  }
}
